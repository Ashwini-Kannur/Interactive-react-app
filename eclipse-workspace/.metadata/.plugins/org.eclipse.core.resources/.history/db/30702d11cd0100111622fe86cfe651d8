package PageObjects;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.FindBy;

public class regPage extends basePage{
	WebDriver driver;
	public regPage(WebDriver driver) {
		super(driver);

	}
	@FindBy(xpath = "//input[@id='input-firstname']")
	WebElement firstName;
	
	@FindBy(xpath = "//input[@id='input-lastname']")
	WebElement lastName;
	
	@FindBy(xpath = "//input[@id='input-email']")
	WebElement email;
	
	@FindBy(xpath 	= "//input[@id='input-telephone']")
	WebElement telephone;
	
	@FindBy(xpath = "//input[@id='input-password']")
	WebElement passwordEle;
	
	@FindBy(xpath = "//input[@id='input-confirm']")
	WebElement confirmPasswordEle;
	
	@FindBy(xpath = "//input[@name='agree']")
	WebElement policyEle;
	
	@FindBy(xpath = "//input[@value='Continue']")
	WebElement continueEle;
	
	@FindBy(xpath = "//h1[normalize-space()='Your Account Has Been Created!']")
	WebElement msgConfirmEle;
	
	//Action Meth
	public void setFirstName(String fName) {
		firstName.sendKeys(fName);
	}
	public void setLastname(String lName) {
		lastName.sendKeys(lName);
	}
	public void setEmail(String mail) {
		email.sendKeys(mail);
	}
	public void setTelephone(String phoneno) {
		telephone.sendKeys(phoneno);
	}
	public void setPassword(String pwd) {
		passwordEle.sendKeys(pwd);
	}
	public void setConfirmPassword(String confirmPwd) {
		confirmPasswordEle.sendKeys(confirmPwd);
	}
	public void checkPolicy() {
		policyEle.click();
	}
	public void continueBtn() {
		continueEle.click();
	}
	
	
	public String getConfirmMessage() {
		try {
			return(msgConfirmEle.getText());
		}
		catch (Exception e) {
			return e.getMessage();
		}
	}
}
